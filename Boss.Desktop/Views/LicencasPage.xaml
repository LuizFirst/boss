      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Grid Margin="30">
        <StackPanel>
            <TextBlock Text="Gestão de Licenças" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>

            <Button Content="Gerar Licença Trial" Height="50" Width="250" Margin="0,20,0,0" Background="{StaticResource PrimaryColor}" Click="BtnGerarTrial_Click"/>

            <TextBlock Text="Licenças Ativas" Margin="0,30,0,10" FontSize="18"/>
            <!-- Lista virá aqui -->
        </StackPanel>
    </Grid>
</Page>