<Window x:Class="Boss.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Boss - Gerenciador de Desbloqueios" 
        Height="720" Width="1280"
        WindowState="Maximized"
        Background="{StaticResource DarkBackground}">

    <Grid>
        <!-- Sidebar -->
        <Grid Width="260" HorizontalAlignment="Left" Background="#0A0A0A">
            <StackPanel>
                <!-- Logo -->
                <Border Background="#111111" Padding="20" Margin="0,20,0,30">
                    <TextBlock Text="BOSS" 
                               FontSize="42" 
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryColor}"
                               HorizontalAlignment="Center"/>
                </Border>

                <!-- Menu -->
                <Button Content="🏠  Dashboard" Style="{StaticResource MenuButton}" Click="Dashboard_Click"/>
                <Button Content="🔍  Pesquisar Procedimentos" Style="{StaticResource MenuButton}" Click="Procedimentos_Click"/>
                <Button Content="⭐  Meus Favoritos" Style="{StaticResource MenuButton}"/>
                <Button Content="📖  Histórico" Style="{StaticResource MenuButton}"/>
                <Button Content="✉️  Solicitar Método" Style="{StaticResource MenuButton}"/>

                <Separator Margin="20,15,20,15" Background="#333"/>

                <!-- Apenas Admin -->
                <Button Content="👥  Usuários" Style="{StaticResource MenuButton}"/>
                <Button Content="📋  Pedidos Pendentes" Style="{StaticResource MenuButton}"/>
                <Button Content="🔑  Licenças" Style="{StaticResource MenuButton}" Click="Licencas_Click"/>

                <Separator Margin="20,15,20,15" Background="#333"/>

                <Button Content="⚙️  Configurações" Style="{StaticResource MenuButton}" Margin="0,10,0,0"/>
                <Button Content="🚪  Sair do Sistema" Style="{StaticResource MenuButton}" Foreground="#FF5555"/>
            </StackPanel>
        </Grid>

        <!-- Área Principal -->
        <Grid Margin="260,0,0,0">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>