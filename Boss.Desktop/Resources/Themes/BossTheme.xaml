<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Cores Principais -->
    <SolidColorBrush x:Key="PrimaryColor" Color="#E63939"/>
    <!-- Vermelho -->
    <SolidColorBrush x:Key="DarkBackground" Color="#0F0F0F"/>
    <SolidColorBrush x:Key="CardBackground" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#B0B0B0"/>
    <SolidColorBrush x:Key="BorderColor" Color="#333333"/>

    <!-- Estilo Geral da Janela -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource DarkBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>

</ResourceDictionary>